local function runCombatCoreBrain()
    if CombatThreadActive then return end
    CombatThreadActive = true

    task.spawn(function()
        while (FightOrFlightActive or DirectAttackTarget ~= nil or RandomAttackActive) and Humanoid and RootPart and RootPart.Parent do
            task.wait(0.02)
            
            local targetEnemy = nil
            local closestDist = 9999
            local isAssassinationMode = false
            
            if DirectAttackTarget and DirectAttackTarget.Character and DirectAttackTarget.Character:FindFirstChild("Humanoid") and DirectAttackTarget.Character.Humanoid.Health > 0 then
                local isMaster = (DirectAttackTarget.UserId == MASTER_USER_ID) or (DirectAttackTarget.Name:lower() == "infinitemndev")
                if not isMaster or OwnerFireAllowed then
                    local eRoot = DirectAttackTarget.Character:FindFirstChild("HumanoidRootPart")
                    if eRoot then
                        targetEnemy = DirectAttackTarget.Character
                        closestDist = (eRoot.Position - RootPart.Position).Magnitude
                        isAssassinationMode = true
                    end
                end
            end
            
            if not targetEnemy and RandomAttackActive then
                if RandomCurrentTarget and RandomCurrentTarget.Character and RandomCurrentTarget.Character:FindFirstChild("Humanoid") and RandomCurrentTarget.Character.Humanoid.Health > 0 then
                    local eRoot = RandomCurrentTarget.Character:FindFirstChild("HumanoidRootPart")
                    if eRoot then
                        targetEnemy = RandomCurrentTarget.Character
                        closestDist = (eRoot.Position - RootPart.Position).Magnitude
                    end
                else
                    RandomCurrentTarget = nil
                    local nearestPlayer = nil
                    local nearestDist = 9999
                    
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                            local isMaster = (p.UserId == MASTER_USER_ID) or (p.Name:lower() == "infinitemndev")
                            if not isMaster or OwnerFireAllowed then
                                local pRoot = p.Character:FindFirstChild("HumanoidRootPart")
                                if pRoot then
                                    local d = (pRoot.Position - RootPart.Position).Magnitude
                                    if d < nearestDist then
                                        nearestDist = d
                                        nearestPlayer = p
                                    end
                               end
                            end
                        end
                    end
                    
                    if nearestPlayer then
                        RandomCurrentTarget = nearestPlayer
                        targetEnemy = nearestPlayer.Character
                        closestDist = nearestDist
                        speakInGame("Rampage targeting signature: " .. nearestPlayer.Name)
                    end
                end
            end
            
            if not targetEnemy and FightOrFlightActive then
                for name, data in pairs(RecentAttackers) do
                    if os.clock() - data.timeStamp > 10 or not data.player.Character or not data.player.Character:FindFirstChild("Humanoid") or data.player.Character.Humanoid.Health <= 0 then
                        RecentAttackers[name] = nil
                    else
                        local eRoot = data.player.Character:FindFirstChild("HumanoidRootPart")
                        if eRoot then
                            local d = (eRoot.Position - RootPart.Position).Magnitude
                            if d < closestDist then closestDist = d; targetEnemy = data.player.Character end
                        end
                    end
                end
            end

            local healthRatio = Humanoid.Health / Humanoid.MaxHealth
            
            if healthRatio <= 0.35 and targetEnemy and not isAssassinationMode and not RandomAttackActive and os.clock() > FlightPanicUntil then
                FlightPanicUntil = os.clock() + 20
            end

            if os.clock() < FlightPanicUntil and not isAssassinationMode and not RandomAttackActive then
                IsFollowing = false; IsWandering = false
                if targetEnemy and targetEnemy:FindFirstChild("HumanoidRootPart") then
                    local escapeDirection = (RootPart.Position - targetEnemy.HumanoidRootPart.Position).Unit
                    walkTo(RootPart.Position + (escapeDirection * 30), 4)
                end
            elseif targetEnemy and targetEnemy:FindFirstChild("HumanoidRootPart") then
                IsFollowing = false; IsWandering = false
                local enemyRoot = targetEnemy.HumanoidRootPart
                local targetLook = Vector3.new(enemyRoot.Position.X, RootPart.Position.Y, enemyRoot.Position.Z)
                RootPart.CFrame = CFrame.lookAt(RootPart.Position, targetLook)
                
                scanAndEquipBestWeapon()
                
                if closestDist > 3.5 then
                    Humanoid:MoveTo(enemyRoot.Position)
                else
                    if Humanoid then Humanoid:MoveTo(RootPart.Position) end
                    RootPart.CFrame = CFrame.lookAt(RootPart.Position, targetLook)
                end

                pcall(function()
                    VirtualUser:Button1Down(Vector2.new(0, 0))
                    task.wait(0.01)
                    VirtualUser:Button1Up(Vector2.new(0, 0))
                end)
                
                local currentTool = Character:FindFirstChildOfClass("Tool")
                if currentTool then currentTool:Activate() end
            end
        end
        CombatThreadActive = false
    end)
end

local function findPlayer(nameStr)
    if not nameStr or nameStr == "" then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower() == nameStr:lower() or p.DisplayName:lower() == nameStr:lower() then return p end
    end
    return nil
end

-- =====================================================================
-- EXECUTOR INTERCEPTOR AND COMMAND PARSER
-- =====================================================================
local function processIncomingPayload(sender, message)
    local cleanMsg = message:gsub("%s+", " "):gsub("^%s+", ""):gsub("%s+$", "")
    local cleanMsgLower = cleanMsg:lower()
    local senderUserIdStr = tostring(sender.UserId)
    local senderNameLower = sender.Name:lower()
    local isAdmin = Admins[senderUserIdStr] or Admins[senderNameLower] or (sender.UserId == MASTER_USER_ID)
    
    if ResetAwaitingConfirmation and sender == ResetAdminUser then
        local validationInput = cleanMsgLower:gsub("%s+", "")
        if validationInput == "yes" then
            ResetAwaitingConfirmation = false; ResetAdminUser = nil
            pcall(function()
                if httpRequest == HttpService.PostAsync then
                    HttpService:PostAsync(RENDER_URL, HttpService:JSONEncode({message = "__INTERNAL_WIPE_ALL_MEMORY__"}), Enum.HttpContentType.ApplicationJson)
                else
                    httpRequest({
                        Url = RENDER_URL,
                        Method = "POST",
                        Headers = { ["Content-Type"] = "application/json" },
                        Body = HttpService:JSONEncode({message = "__INTERNAL_WIPE_ALL_MEMORY__"})
                    })
                end
            end)
            speakInGame("Memory Reset Successfully")
            return
        elseif validationInput == "no" then
            ResetAwaitingConfirmation = false; ResetAdminUser = nil
            speakInGame("Memory Reset Canceled")
            return
        end
    end

    if string.sub(cleanMsg, 1, 5) == "!pip " then
        if not isAdmin then return end
        local fullCmd = string.sub(cleanMsg, 6)
        local args = string.split(fullCmd, " ")
        local baseCmd = args[1]:lower()
        
        -- !pip interact
        if baseCmd == "interact" then
            local engaged, targetName = executeAdvancedInteract()
            if engaged then
                speakInGame("Fired proximity channels onto object signature: " .. targetName)
            else
                speakInGame("Interact Failure: No valid proximity nodes within physical vector lines.")
            end
            return
            
        elseif baseCmd == "ownerfirefalse" then
            OwnerFireAllowed = false
            speakInGame("Safety protocol active. Creator protection confirmed.")
            return
            
        elseif baseCmd == "ownerfiretrue" then
            OwnerFireAllowed = true
            speakInGame("Safety overrides removed. Creator target signature unlocked.")
            return
            
        elseif baseCmd == "randomattack" then
            stopAllMovement()
            RandomAttackActive = true
            speakInGame("Server rampage protocol initiated.")
            setupThreatTracking()
            runCombatCoreBrain()
            return
            
        elseif baseCmd == "randomattackstop" then
            RandomAttackActive = false
            RandomCurrentTarget = nil
            speakInGame("Rampage suspended. Standing down.")
            return
            
        elseif baseCmd == "alwaysequip" and args[2] then
            local tName = string.sub(fullCmd, string.find(fullCmd, " ") + 1)
            AlwaysEquipEnabled = true
            AlwaysEquipToolName = tName
            equipToolByName(tName)
            speakInGame("Always equipping: " .. tName)
            return
            
        elseif baseCmd == "unalwaysequip" then
            AlwaysEquipEnabled = false
            AlwaysEquipToolName = ""
            speakInGame("Always-equip lock overridden.")
            return
            
        elseif baseCmd == "attack" and args[2] then
            local targetPlayerObj = findPlayer(args[2])
            if targetPlayerObj then
                stopAllMovement()
                DirectAttackTarget = targetPlayerObj
                speakInGame("Locked onto " .. targetPlayerObj.Name .. ". Engaging.")
                setupThreatTracking()
                runCombatCoreBrain()
            else
                speakInGame("Attack Error: Target signature missing.")
            end
            return
            
        elseif baseCmd == "stopattack" then
            DirectAttackTarget = nil
            speakInGame("Assassination parameters dropped.")
            return
            
        elseif baseCmd == "datareset" then
            ResetAwaitingConfirmation = true
            ResetAdminUser = sender
            speakInGame("Are you sure you want to run this command? answer with \"Yes\" or \"No\"")
            return
            
        elseif baseCmd == "equip" and args[2] then
            local toolNameQuery = string.sub(fullCmd, string.find(fullCmd, " ") + 1)
            local success = equipToolByName(toolNameQuery)
            if success then speakInGame("Equipped " .. toolNameQuery) else speakInGame("Tool not found.") end
            return
            
        elseif baseCmd == "blacklist" and args[2] then
            local targetName = args[2]:lower()
            if targetName ~= tostring(MASTER_USER_ID) and targetName ~= "infinitemndev" then
                Admins[targetName] = nil
                speakInGame(args[2] .. " stripped of admin access.")
            else
                speakInGame("Access Denied.")
            end
            return
            
        elseif baseCmd == "autojumpenable" then
            AutoJumpEnabled = true
            speakInGame("Auto-jump navigation: ON.")
            return
            
        elseif baseCmd == "autojumpdisable" then
            AutoJumpEnabled = false
            speakInGame("Auto-jump navigation: OFF.")
            return
            
        elseif baseCmd == "fightorflightenable" then
            FightOrFlightActive = true
            setupThreatTracking()
            runCombatCoreBrain()
            speakInGame("Fight or Flight: ACTIVE.")
            return
            
        elseif baseCmd == "fightorflightdisable" then
            FightOrFlightActive = false
            FlightPanicUntil = 0
            RecentAttackers = {}
            speakInGame("Fight or Flight: DISABLED.")
            return

        elseif baseCmd == "follow" then
            stopAllMovement()
            IsFollowing = true
            TargetPlayer = args[2] and findPlayer(args[2]) or Players:GetPlayerByUserId(MASTER_USER_ID)
            if TargetPlayer then speakInGame("Following " .. TargetPlayer.Name) runFollowThread() end
            return
            
        elseif baseCmd == "freeze" then
            stopAllMovement()
            speakInGame("Locomotive systems frozen.")
            return
            
        elseif baseCmd == "wander" then
            stopAllMovement()
            IsWandering = true
            speakInGame("Autonomous exploration active.")
            runWanderThread()
            return
            
        elseif baseCmd == "pathfindingenable" then
            PathfindingEnabled = true
            speakInGame("PathfindingService: ONLINE.")
            return
            
        elseif baseCmd == "pathfindingdisable" then
            PathfindingEnabled = false
            speakInGame("PathfindingService: OFFLINE.")
            return
            
        elseif baseCmd == "kill" then
            if Humanoid then Humanoid.Health = 0 end
            return
            
        elseif baseCmd == "admin" and args[2] then
            local target = findPlayer(args[2])
            if target then
                Admins[tostring(target.UserId)] = true
                Admins[target.Name:lower()] = true
                speakInGame(target.Name .. " granted admin permissions.")
            end
            return
            
        elseif baseCmd == "disable" then
            AiGenerationEnabled = false; speakInGame("Charlie AI generation: OFFLINE.")
            return
            
        elseif baseCmd == "enable" then
            AiGenerationEnabled = true; speakInGame("Charlie AI generation: ONLINE.")
            return
            
        -- !pip help
        elseif baseCmd == "help" then
            speakInGame("Cmds: interact, ownerfirefalse, ownerfiretrue, randomattack, randomattackstop, alwaysequip, unalwaysequip, attack, stopattack, datareset, equip, blacklist, autojump, fightorflight, follow, freeze, wander, pathfind")
            return
        end
    end

    if isAdmin then
        if cleanMsgLower == "!pip globalchatenable" then GlobalChatActive = true; speakInGame("Global scan active.") return
        elseif cleanMsgLower == "!pip globalchatdisable" then GlobalChatActive = false; speakInGame("Global scan disabled.") return end
    end

    if not AiGenerationEnabled or (not isAdmin and not GlobalChatActive) or sender == LocalPlayer then return end

    local dataPayload = { userId = sender.UserId, username = sender.Name, message = cleanMsg }
    task.spawn(function()
        local responseBody = nil
        pcall(function()
            if httpRequest == HttpService.PostAsync then
                responseBody = HttpService:PostAsync(RENDER_URL, HttpService:JSONEncode(dataPayload), Enum.HttpContentType.ApplicationJson)
            else
                local success, res = pcall(function()
                    return httpRequest({
                        Url = RENDER_URL,
                        Method = "POST",
                        Headers = { ["Content-Type"] = "application/json" },
                        Timeout = 25,
                        Body = HttpService:JSONEncode(dataPayload)
                    })
                end)
                if success and res and res.Body then responseBody = res.Body end
            end
        end)
        
        if responseBody then
            local successDecode, responseData = pcall(function() return HttpService:JSONDecode(responseBody) end)
            if successDecode and responseData then speakInGame(responseData.response) end
        end
    end)
end

