local function equipToolByName(nameStr)
    if not nameStr or nameStr == "" or not Humanoid then return false end
    for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name:lower() == nameStr:lower() or string.find(tool.Name:lower(), nameStr:lower())) then
            Humanoid:EquipTool(tool)
            return true
        end
    end
    return false
end

local function scanAndEquipBestWeapon()
    if not Character or not Humanoid then return false end
    
    if AlwaysEquipEnabled and AlwaysEquipToolName ~= "" then
        local foundInHand = Character:FindFirstChild(AlwaysEquipToolName)
        if foundInHand then return true end
        local success = equipToolByName(AlwaysEquipToolName)
        if success then return true end
    end
    
    local bestWeapon = nil
    local function checkContainer(container)
        for _, tool in ipairs(container:GetChildren()) do
            if tool:IsA("Tool") then
                local toolName = tool.Name:lower()
                for _, keyword in ipairs(WeaponKeywords) do
                    if string.find(toolName, keyword) then bestWeapon = tool; break end
                end
            end
        end
    end

    checkContainer(LocalPlayer.Backpack)
    if not bestWeapon then checkContainer(Character) end

    if bestWeapon and bestWeapon.Parent == LocalPlayer.Backpack then
        Humanoid:EquipTool(bestWeapon)
        return true
    elseif bestWeapon then
        return true
    end
    return false
end

