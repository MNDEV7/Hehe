-- =====================================================================
-- PRODUCTION STABILIZED PATH MOTOR (ANTI-STUTTER ENGINE)
-- =====================================================================
local function walkTo(goalPos, arriveRadius)
    if not Humanoid or not RootPart or Humanoid.Health <= 0 then return "died" end
    if IsCurrentlyWalking then return "busy" end 
    IsCurrentlyWalking = true

    local globalStart = os.clock()

    if not PathfindingEnabled then
        Humanoid:MoveTo(goalPos)
        local finished = false
        local finishedConn = Humanoid.MoveToFinished:Connect(function() finished = true end)
        while not finished do
            task.wait(0.05)
            if not RootPart.Parent or Humanoid.Health <= 0 then finishedConn:Disconnect(); IsCurrentlyWalking = false; return "died" end
            if os.clock() - globalStart > TIMEOUT then finishedConn:Disconnect(); IsCurrentlyWalking = false; return "timeout" end
            if (RootPart.Position - goalPos).Magnitude <= arriveRadius then break end
        end
        finishedConn:Disconnect()
        IsCurrentlyWalking = false
        return "arrived"
    end

    local path = PathfindingService:CreatePath(PATH_PARAMS)
    local ok   = pcall(function() path:ComputeAsync(RootPart.Position, goalPos) end)

    if not ok or path.Status ~= Enum.PathStatus.Success then
        Humanoid:MoveTo(goalPos)
        IsCurrentlyWalking = false
        return "arrived"
    end

    local waypoints = path:GetWaypoints()

    for i = 2, #waypoints do
        if not RootPart.Parent or Humanoid.Health <= 0 then IsCurrentlyWalking = false; return "died" end
        if (RootPart.Position - goalPos).Magnitude <= arriveRadius then break end
        if os.clock() - globalStart > TIMEOUT then Humanoid:MoveTo(RootPart.Position); IsCurrentlyWalking = false; return "timeout" end

        local wp = waypoints[i]
        if wp.Action == Enum.PathWaypointAction.Jump or AutoJumpEnabled then
            Humanoid.Jump = true
        end

        Humanoid:MoveTo(wp.Position)

        local wpDone     = false
        local wpStart    = os.clock()
        local jumpedAt   = -999
        local lastPos    = RootPart.Position
        local lastMoveAt = os.clock()

        local conn = Humanoid.MoveToFinished:Connect(function() wpDone = true end)

        while not wpDone do
            -- Adaptive yielding: checks quick steps when close to keep momentum high
            local distToWp = (RootPart.Position - wp.Position).Magnitude
            if distToWp <= 2.5 then wpDone = true break end
            
            task.wait(0.02)
            if not RootPart.Parent or Humanoid.Health <= 0 then conn:Disconnect(); IsCurrentlyWalking = false; return "died" end
            if os.clock() - globalStart > TIMEOUT then conn:Disconnect(); Humanoid:MoveTo(RootPart.Position); IsCurrentlyWalking = false; return "timeout" end
            if (RootPart.Position - goalPos).Magnitude <= arriveRadius then conn:Disconnect(); wpDone = true; break end

            local moved = (RootPart.Position - lastPos).Magnitude
            lastPos = RootPart.Position
            if moved > 0.05 then lastMoveAt = os.clock() end

            if (os.clock() - lastMoveAt) >= JUMP_AFTER and (os.clock() - jumpedAt) > JUMP_AFTER then
                Humanoid.Jump = true
                jumpedAt = os.clock()
                task.wait(0.05)
                Humanoid:MoveTo(wp.Position)
            end

            if os.clock() - wpStart > WP_TIMEOUT then
                conn:Disconnect()
                IsCurrentlyWalking = false
                return walkTo(goalPos, arriveRadius) 
            end
        end
        conn:Disconnect()
    end
    IsCurrentlyWalking = false
    return "arrived"
end

